#!/bin/bash
set -euo pipefail

CONFIG_FILE="/usr/local/etc/vpn-route-automator.conf"
ROUTES=("192.168.69.12/24" "192.168.123.0/24")
VPN_INTERFACE="ppp0"
VPN_PID_FILE="/var/run/ppp0.pid"
VPN_NAME="Company VPN"

if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

LOG_DIR="$HOME/Library/Logs/vpn-route-automator"
LOG_FILE="$LOG_DIR/automator.log"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }
setup_logs() { mkdir -p "$LOG_DIR"; touch "$LOG_FILE"; chmod 644 "$LOG_FILE"; }

is_vpn_active() {
    local iface=$1
    log "检查 VPN 状态...($iface)"
    for i in {1..5}; do
        if ifconfig "$iface" 2>/dev/null | grep -q 'flags=.*<.*UP.*RUNNING'; then
            log "${iface} --> 接口已激活"
            vpn_status=$(scutil --nc status "$VPN_NAME" 2>/dev/null | awk '/^Connected/')
            [[ -n "$vpn_status" ]] && { log "$VPN_NAME --> ${iface}: VPN 连接已建立"; return 0; }
        fi
        sleep 1
    done
    log "$VPN_NAME --> ${iface}: VPN 未启动"
    return 1
}

route_check() {
    sudo route -n get "$1" 2>&1 | grep -q "interface: $2$"
}

manage_route() {
    local event=$1
    log "处理事件：$event"
    case "$event" in
        *Created*)
            log "检测到 VPN 连接事件"
            for i in {1..10}; do
                log "等待网络接口初始化...($i/10)"
                if is_vpn_active $VPN_INTERFACE; then
                    log "VPN 已连接，准备添加路由"
                    for route in "${ROUTES[@]}"; do
                        log "处理路由：$route"
                        add_route "$route" ${VPN_INTERFACE}
                    done
                    return
                fi
                sleep 1
            done
            log "警告：VPN 接口未在时限内就绪"
            ;;
        *Removed*)
            log "检测到 VPN 断开事件"
            for route in "${ROUTES[@]}"; do
                if route_check "$route" ${VPN_INTERFACE}; then
                    log "清理路由：$route"
                    remove_route "$route" ${VPN_INTERFACE}
                else
                    log "路由 $route 不存在，无需清理"
                fi
            done
            ;;
    esac
}

add_route() {
    local route_target=$1 interface=$2
    if ! route_check "$route_target" "$interface"; then
        log "正在添加路由 $route_target → $interface"
        if sudo route add "$route_target" -interface "$interface" >> "$LOG_FILE" 2>&1; then
            log "成功添加路由：$route_target → $interface"
        else
            log "添加路由失败 $route_target → $interface"
        fi
    else
        log "路由 $route_target → $interface 已存在，跳过添加"
    fi
}

remove_route() {
    local route_target=$1 interface=$2
    if route_check "$route_target" "$interface"; then
        log "正在移除路由 $route_target → $interface"
        if sudo route delete "$route_target" -interface "$interface" >> "$LOG_FILE" 2>&1; then
            log "成功移除路由：$route_target → $interface"
        else
            log "移除路由失败 $route_target → $interface"
        fi
    else
        log "路由 $route_target → $interface 不存在，无需移除"
    fi
}

main() {
    setup_logs
    log "=========================================="
    log "VPN 路由自动化工具启动"
    log "配置文件：$CONFIG_FILE"
    log "VPN 名称：$VPN_NAME"
    log "VPN 接口：$VPN_INTERFACE"
    log "路由数量：${#ROUTES[@]}"
    log "=========================================="
    if [[ -f "$VPN_PID_FILE" ]]; then
        log "PID 文件存在，VPN 已连接，开始添加路由"
        manage_route "Created"
    else
        log "PID 文件不存在，VPN 已断开，开始清理路由"
        manage_route "Removed"
    fi
}

main
